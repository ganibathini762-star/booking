{
  "name": "@ticketflow/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file=.env dist/index.js | pino-pretty",
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "db:generate": "tsx ./node_modules/.bin/drizzle-kit generate",
    "db:migrate": "tsx ./node_modules/.bin/drizzle-kit migrate",
    "db:push": "tsx ./node_modules/.bin/drizzle-kit push",
    "db:seed": "node --env-file=.env dist/db/seed.js",
    "db:studio": "tsx ./node_modules/.bin/drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/swagger-ui": "^0.6.1",
    "@neondatabase/serverless": "^0.10.4",
    "@supabase/supabase-js": "^2.101.1",
    "@upstash/redis": "^1.34.3",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.35.2",
    "drizzle-orm": "^0.40.0",
    "get-stream": "^9.0.1",
    "hono": "^4.7.4",
    "ioredis": "^5.4.2",
    "jose": "^5.10.0",
    "meilisearch": "^0.57.0",
    "nodemailer": "^6.10.0",
    "pdfkit": "^0.18.0",
    "pino": "^9.6.0",
    "postgres": "^3.4.8",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.5",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.1",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.30.4",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  }
}
