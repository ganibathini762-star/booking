# ===== API (apps/api/.env) =====
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/ticketflow?sslmode=require
REDIS_URL=rediss://default:token@xxx.upstash.io:6379
JWT_SECRET=change-me-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=change-me-super-secret-refresh-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_BUCKET_NAME=ticketflow
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MEILISEARCH_URL=https://ms-xxx.meilisearch.io
MEILISEARCH_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ===== WEB (apps/web/.env) =====
VITE_API_URL=http://localhost:3000/api/v1
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
VITE_WS_URL=ws://localhost:3000
